{
  "name": "pakipark-backend",
  "version": "1.0.0",
  "description": "PakiPark Parking Reservation System - Backend API (PostgreSQL/Sequelize)",
  "main": "server.js",
  "scripts": {
    "start":        "node server.js",
    "dev":          "nodemon server.js",
    "seed":         "node config/seed.js",
    "db:sync":      "node scripts/syncSchema.js",
    "db:sync:force":"node scripts/syncSchema.js --force",
    "db:indexes":   "node scripts/syncSchema.js --indexes-only"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-validator": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.14",
    "pg": "^8.13.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}