{
  "name": "pakipark",
  "version": "1.0.0",
  "private": true,
  "description": "PakiPark Smart Parking System — Monorepo (Next.js Frontend + Express Backend)",
  "scripts": {
    "dev:backend":    "cd src/Backend && npm run dev",
    "dev:frontend":   "cd src/Frontend && npm run dev",
    "install:all":    "cd src/Backend && npm install && cd ../Frontend && npm install",
    "build:backend":  "cd src/Backend && npm run build",
    "build:frontend": "cd src/Frontend && npm run build",
    "test":           "jest"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.2",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "next": "15.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.3.3"
  }
}
